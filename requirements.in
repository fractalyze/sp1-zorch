# sp1-zorch runtime dependencies.
#
# Pulled from the Fractalyze package index alongside upstream PyPI:
#   pip install -r requirements.in \
#     --extra-index-url https://fractalyze.github.io/pypi/simple/
#
# sp1-zorch is the SP1-specific consumer of zorch's agnostic blocks; zorch
# itself arrives as a Bazel module (see MODULE.bazel), not a pip dep. zk_dtypes
# (native finite-field dtypes) arrives transitively via jax and is used directly
# on the SP1 byte-match path.
absl-py
numpy
# Lockstep with the zorch git pin in MODULE.bazel (zkx marker contract) —
# bump both together; the rationale lives on the git_override there. The wheel
# set must match the jax that the pinned zorch commit builds against, or the
# GPU codeword desyncs, which CPU-only CI cannot catch.
# Migrated to the consolidated fractalyze/jax (the 0.10.0 line, renamed from the
# old 0.0.5 zkx stack); zkx-cuda-pjrt is now published as jax-cuda12-pjrt. This
# wheel set matches the pinned zorch commit (72b9cf71, zorch#283), which builds
# against jax 0.10.0.dev20260628052515. zorch#283's jagged PCS is markerless
# (recompile-free symbolic-K export), so this lockstep no longer rides a
# sumcheck/jagged marker-version cut — but the wheel must still match the pin.
jax==0.10.0.dev20260701084712
jaxlib==0.10.0.dev20260701084712
jax-cuda12-pjrt==0.10.0.dev20260701084712
jax-cuda12-plugin==0.10.0.dev20260701084712
# zk_dtypes ships the native field dtypes jax lowers. It arrives transitively
# via jax, but the resolver leaves it at the lowest compatible version, which
# lags the jax build: 0.0.7 adds the Pallas scalar field (pallas_sf) the jax
# wheel now references (Pasta GPU MSM, fractalyze/zkx#699). Pin it explicitly
# so the lock tracks the jax wheel, not an older transitive pick.
zk-dtypes==0.0.7

# SP1 chip definitions (constraints + LogUp interactions) exported from
# riscv-witness; consumed by the shard fixture loader. Same pin as whir-zorch.
rw-constraints @ https://github.com/fractalyze/pypi/releases/download/riscv-witness-dev-20260524141732/rw_constraints-0.1.0.dev20260524141732-py3-none-any.whl

# Benchmark harness (shared across fractalyze repos); used only by the
# //sp1_zorch/...:*bench* py_binary targets, not by the sp1-zorch wheel itself.
zkbench==0.4.0
