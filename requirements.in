# sp1-zorch runtime dependencies.
#
# Pulled from the Fractalyze package index alongside upstream PyPI:
#   pip install -r requirements.in \
#     --extra-index-url https://fractalyze.github.io/pypi/simple/
#
# sp1-zorch is the SP1-specific consumer of zorch's agnostic blocks; zorch
# itself arrives as a Bazel module (see MODULE.bazel), not a pip dep. zk_dtypes
# (native finite-field dtypes) arrives transitively via jax and is used directly
# on the SP1 byte-match path.
absl-py
numpy
jax==0.0.5.dev20260602054734
jaxlib==0.0.5.dev20260602054734
jax-cuda12-plugin==0.0.5.dev20260524000415
zkx-cuda-pjrt==0.0.5.dev20260602054734

# SP1 chip definitions (constraints + LogUp interactions) exported from
# riscv-witness; consumed by the shard fixture loader. Same pin as whir-zorch.
rw-constraints @ https://github.com/fractalyze/pypi/releases/download/riscv-witness-dev-20260524141732/rw_constraints-0.1.0.dev20260524141732-py3-none-any.whl

# Benchmark harness (shared across fractalyze repos); used only by the
# //sp1_zorch/...:*bench* py_binary targets, not by the sp1-zorch wheel itself.
