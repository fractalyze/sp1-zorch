# Host-bytes ctypes binding for SP1's shard verifier (no JAX involvement).
py_library(
    name = "sp1_ffi",
    srcs = ["sp1_ffi.py"],
    visibility = ["//visibility:public"],
)

py_binary(
    name = "verify_prove_shard",
    srcs = ["verify_prove_shard.py"],
    # rsp byte-match of the assembled ProveChain (~1.5 GB/shard, GPU trace
    # commit) — a runnable, not a unit test:
    #   bazel run //sp1_zorch/shard_prover:verify_prove_shard -- \
    #       --shard_dir=/path/to/rsp_dump/shardN
    deps = [
        ":prove_shard",
        ":replay",
        ":shard_prover",
        ":sp1_ffi",
        "//sp1_zorch/commit:smcs",
        "//sp1_zorch/logup_gkr",
        "//sp1_zorch/poseidon2:koalabear16",
        "@zorch//zorch/hash:compression",
        "@zorch//zorch/hash:sponge",
        "@zorch//zorch/hash/poseidon2",
        "@zorch//zorch/poly:poly",
        requirement("absl_py"),
        requirement("jax"),
        requirement("jax_cuda12_plugin"),
        requirement("zk_dtypes"),
        requirement("jax_cuda12_pjrt"),
    ],
)

py_binary(
    name = "verify_shard_fixture",
    srcs = ["verify_shard_fixture.py"],
    # Fixture check over a local rsp GPU-trace capture (~1.5 GB/shard) — a
    # runnable, not a unit test:
    #   bazel run //sp1_zorch/shard_prover:verify_shard_fixture -- \
    #       --shard_dir=/path/to/rsp_dump/shardN
    deps = [
        ":shard_prover",
        requirement("absl_py"),
        requirement("zk_dtypes"),
    ],
)
